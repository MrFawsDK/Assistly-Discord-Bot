# Kopiér denne fil til ".env" og udfyld dine værdier

# ─── Discord ─────────────────────────────────────────────────────────────────

# Discord bot token fra https://discord.com/developers/applications
DISCORD_TOKEN=dit_token_her

# Din bots Application ID (fra Developer Portal > General Information)
CLIENT_ID=din_client_id_her

# ID på den server du tester på (højreklik på server > Kopiér server-ID)
GUILD_ID=din_guild_id_her

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Vælg hvilken AI der skal bruges: 'ollama' (lokal) eller 'api' (ekstern)

AI_PROVIDER=ollama

# ─── Ollama (lokal) ──────────────────────────────────────────────────────────
# Kræver Ollama installeret: https://ollama.com
# Bruges kun når AI_PROVIDER=ollama

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Ekstern API ─────────────────────────────────────────────────────────────
# Bruges kun når AI_PROVIDER=api
# Virker med enhver OpenAI-kompatibel udbyder:
#
#   OpenAI:      API_BASE_URL=https://api.openai.com/v1
#   Groq:        API_BASE_URL=https://api.groq.com/openai/v1
#   Mistral:     API_BASE_URL=https://api.mistral.ai/v1
#   Together AI: API_BASE_URL=https://api.together.xyz/v1
#   Gemini:      API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

API_BASE_URL=https://api.openai.com/v1
API_KEY=din-api-nøgle-her
API_MODEL=gpt-4o